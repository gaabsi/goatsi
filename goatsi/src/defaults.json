{
  "xgboost": {
    "seed": 77,
    "train_size": 0.8,
    "n_iter": 20,
    "cv_n_splits": 5,
    "optimize_on": {
      "classification": "roc_auc",
      "regression": "r2"
    },
    "log": {
      "classification": ["roc_auc", "accuracy", "precision", "recall", "f1", "average_precision"],
      "regression": ["r2", "neg_root_mean_squared_error", "neg_mean_absolute_error"]
    },
    "display": {
      "neg_root_mean_squared_error": "RMSE",
      "neg_mean_absolute_error": "MAE",
      "r2": "R²",
      "roc_auc": "AUC-ROC",
      "average_precision": "Avg Precision",
      "accuracy": "Accuracy",
      "precision": "Precision",
      "recall": "Recall",
      "f1": "F1"
    },
    "enable_categorical": true,
    "tree_method": "hist",
    "threads": -1,
    "param_grid": {
      "n_estimators": [50, 500],
      "learning_rate": [0.01, 0.3],
      "max_depth": [3, 10],
      "min_child_weight" : [1, 10],
      "subsample" : [0.4, 0.8],
      "colsample_bytree" : [0.4, 0.6],
      "gamma" : [0.0, 1.0],
      "reg_alpha" : [0.0, 10.0],
      "reg_lambda" : [0.0, 10.0]
    }
  }
}
